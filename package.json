  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coder-ao/masonry-flow.git"
  },
  "homepage": "https://coder-ao.github.io/masonry-flow/",
  "bugs": {
    "url": "https://github.com/coder-ao/masonry-flow/issues"
  },
