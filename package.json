  "license": "MIT",
  "type": "module",
  "main": "dist/masonry-flow.umd.cjs",
  "module": "dist/masonry-flow.es.js",
  "exports": {
    ".": {
      "import": "./dist/masonry-flow.es.js",
      "require": "./dist/masonry-flow.umd.cjs"
    }
  },
  "sideEffects": [
